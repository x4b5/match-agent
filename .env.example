# Matchflix — Environment Configuration
# Kopieer naar .env en pas aan voor jouw omgeving.

# --- Paden ---
# MATCHFLIX_ICLOUD_BASE=~/Library/Mobile Documents/com~apple~CloudDocs/matchflix
# MATCHFLIX_DB_PATH=~/Library/Application Support/matchflix/matchflix.db

# --- Logging ---
# MATCHFLIX_LOG_LEVEL=INFO

# --- Ollama ---
OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3.5:27b
# PROFIEL_MODEL=qwen3:8b
# EMBEDDING_MODEL=nomic-embed-text
# QUICK_SCAN_MODEL=qwen3:4b
# STANDAARD_MODEL=qwen3:8b
